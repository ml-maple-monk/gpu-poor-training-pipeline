# Dashboard docker-compose environment.
# Must stay in sync with defaults.toml [dashboard] and [dashboard.compose].
DSTACK_SERVER_PORT=3000
DASHBOARD_PORT=7860
DSTACK_CONTAINER_NAME=verda-dashboard-dstack-server
DASHBOARD_CONTAINER_NAME=verda-dashboard-gradio
HEALTHCHECK_INTERVAL=5s
HEALTHCHECK_TIMEOUT=3s
HEALTHCHECK_RETRIES=20
HEALTHCHECK_START_PERIOD=2s
DSTACK_WAIT_TIMEOUT_SECONDS=30
TRAINER_CONTAINER=minimind-trainer
SEEKER_DATA_DIR=/seeker-data
