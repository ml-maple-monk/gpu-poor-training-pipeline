+# ── Atomic save helper ────────────────────────────────────────────────────────
+def _atomic_torch_save(obj, path):
+    """Save obj to path atomically via a .tmp intermediate."""
+    tmp = path + ".tmp"
+    torch.save(obj, tmp)
+    os.replace(tmp, path)
+
+
+# ── SIGTERM handler ───────────────────────────────────────────────────────────
+_stop_flag = False
+_save_thread = None
+
+
+def _sigterm_handler(signum, frame):
+    global _stop_flag
+    print("[SIGTERM] Received SIGTERM — initiating graceful shutdown", flush=True)
+    _stop_flag = True
+
+    if _save_thread is not None and _save_thread.is_alive():
+        print("[SIGTERM] Waiting up to 30s for save thread to finish...", flush=True)
+        try:
+            _save_thread.join(timeout=30)
+        except KeyboardInterrupt:
+            pass
+        if _save_thread.is_alive():
+            print("[SIGTERM] Save thread did not finish in 30s — proceeding anyway", flush=True)
+
+    try:
+        import glob as _glob
+        for tmp_file in _glob.glob(os.path.join(args.save_dir, "*.tmp")):
+            print(f"[SIGTERM] Removing residual tmp file: {tmp_file}", flush=True)
+            try:
+                os.remove(tmp_file)
+            except OSError:
+                pass
+    except Exception as e:
+        print(f"[SIGTERM] Warning: could not clean tmp files: {e}", flush=True)
+
+    try:
+        _mlflow_finish(status="KILLED")
+        print("[SIGTERM] MLflow run ended with status=KILLED", flush=True)
+    except Exception as e:
+        print(f"[SIGTERM] Warning: MLflow finish failed: {e}", flush=True)
+
+    print("[SIGTERM] Exiting with code 143", flush=True)
+    sys.exit(143)
+
+
