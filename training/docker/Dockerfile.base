ARG BUILDER_IMAGE=nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04
ARG RUNTIME_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04

FROM ${BUILDER_IMAGE} AS builder

RUN echo "$BUILDER_IMAGE" | grep -vq ':latest$'

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_ROOT_USER_ACTION=ignore \
    HF_HOME=/workspace/hf_cache \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    TRANSFORMERS_OFFLINE=0 \
    TOKENIZERS_PARALLELISM=false \
    VLLM_WORKER_MULTIPROC_METHOD=spawn \
    DS_BUILD_OPS=0 \
    CUDA_HOME=/usr/local/cuda \
    VENV_PATH=/opt/venv

ARG TORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/cu128
ARG TORCH_VERSION=2.8.0
ARG TORCHVISION_VERSION=0.23.0
ARG TORCHAUDIO_VERSION=2.8.0
ARG TORCHDATA_VERSION=0.11.0
ARG FLASH_ATTN_VERSION=2.8.3
ARG MAX_JOBS=8

ENV MAX_JOBS=${MAX_JOBS}

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        ffmpeg \
        git \
        git-lfs \
        jq \
        libaio-dev \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        libnuma1 \
        libopenmpi-dev \
        ninja-build \
        openssh-client \
        pkg-config \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        rsync \
        wget \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv "${VENV_PATH}"

ENV PATH="${VENV_PATH}/bin:${PATH}"

WORKDIR /workspace

COPY training/config/requirements.train.base.txt /tmp/requirements.train.base.txt

RUN python -m pip install --upgrade \
        pip \
        "setuptools>=77.0.3,<80" \
        wheel \
        packaging \
        ninja \
        cmake \
    && python -m pip install --no-compile --extra-index-url "${TORCH_CUDA_INDEX_URL}" \
        "torch==${TORCH_VERSION}" \
        "torchvision==${TORCHVISION_VERSION}" \
        "torchaudio==${TORCHAUDIO_VERSION}" \
        "torchdata==${TORCHDATA_VERSION}" \
    && python -m pip install --no-compile --extra-index-url "${TORCH_CUDA_INDEX_URL}" \
        -r /tmp/requirements.train.base.txt \
    && nvcc --version

# Resolve FlashAttention 2 from the actual torch/CUDA tuple so we can use the
# published wheel instead of rebuilding from source.
RUN FLASH_ATTN_VERSION="${FLASH_ATTN_VERSION}" python - <<'PY' > /tmp/flash_attn_wheel_url.txt
import os
import platform
import sys

import torch

if platform.machine() != "x86_64":
    raise SystemExit(f"Unsupported architecture for prebuilt flash-attn wheel: {platform.machine()}")

python_tag = f"cp{sys.version_info.major}{sys.version_info.minor}"
torch_version = ".".join(torch.__version__.split("+", 1)[0].split(".")[:2])
cuda_version = torch.version.cuda or ""
cuda_major = cuda_version.split(".", 1)[0]
abi_suffix = "TRUE" if torch._C._GLIBCXX_USE_CXX11_ABI else "FALSE"
flash_attn_version = os.environ["FLASH_ATTN_VERSION"]

wheel_name = (
    f"flash_attn-{flash_attn_version}+cu{cuda_major}"
    f"torch{torch_version}cxx11abi{abi_suffix}-"
    f"{python_tag}-{python_tag}-linux_x86_64.whl"
)
wheel_url = (
    "https://github.com/Dao-AILab/flash-attention/releases/download/"
    f"v{flash_attn_version}/{wheel_name}"
)

print(f"[flash-attn] python={sys.version.split()[0]}", file=sys.stderr)
print(f"[flash-attn] torch={torch.__version__}", file=sys.stderr)
print(f"[flash-attn] torch.cuda={cuda_version}", file=sys.stderr)
print(f"[flash-attn] cxx11abi={abi_suffix}", file=sys.stderr)
print(f"[flash-attn] wheel={wheel_name}", file=sys.stderr)
print(wheel_url)
PY

RUN curl -fsIL "$(cat /tmp/flash_attn_wheel_url.txt)" >/dev/null \
    && python -m pip install --no-compile "$(cat /tmp/flash_attn_wheel_url.txt)" \
    && rm -f /tmp/flash_attn_wheel_url.txt \
    && find "${VENV_PATH}" -type d -name '__pycache__' -prune -exec rm -rf '{}' + \
    && find "${VENV_PATH}" -type f \( -name '*.pyc' -o -name '*.pyo' -o -name '*.a' -o -name '*.o' \) -delete \
    && python - <<'PY'
import flash_attn
import torch

print(
    {
        "flash_attn": getattr(flash_attn, "__version__", "unknown"),
        "torch": torch.__version__,
        "cuda": torch.version.cuda,
        "gpu": torch.cuda.is_available(),
        "cxx11abi": torch._C._GLIBCXX_USE_CXX11_ABI,
    }
)
PY

FROM ${RUNTIME_IMAGE} AS runtime

RUN echo "$RUNTIME_IMAGE" | grep -vq ':latest$'

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_ROOT_USER_ACTION=ignore \
    HF_HOME=/workspace/hf_cache \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    TRANSFORMERS_OFFLINE=0 \
    TOKENIZERS_PARALLELISM=false \
    VLLM_WORKER_MULTIPROC_METHOD=spawn \
    DS_BUILD_OPS=0 \
    CUDA_HOME=/usr/local/cuda \
    VENV_PATH=/opt/venv \
    PATH=/opt/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        ffmpeg \
        git \
        git-lfs \
        jq \
        libaio1t64 \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        libnuma1 \
        libopenmpi3t64 \
        openssh-client \
        python3 \
        rsync \
        wget \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/venv /opt/venv

WORKDIR /workspace

RUN python - <<'PY'
import flash_attn
import torch
import transformers
import vllm

print(
    {
        "flash_attn": getattr(flash_attn, "__version__", "unknown"),
        "torch": torch.__version__,
        "cuda": torch.version.cuda,
        "gpu": torch.cuda.is_available(),
        "transformers": transformers.__version__,
        "vllm": vllm.__version__,
    }
)
PY

CMD ["python", "-c", "import torch, transformers, vllm; print({'torch': torch.__version__, 'cuda': torch.version.cuda, 'gpu': torch.cuda.is_available(), 'transformers': transformers.__version__, 'vllm': vllm.__version__})"]
